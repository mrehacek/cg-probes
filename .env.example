# cg-probes — environment template. Copy to `.env` and fill in ONLY what you need.
# The offline probe-reproduction path (see REPRODUCE.md) needs NO keys at all:
# the headline embeddings are shipped under benchmark/cache/emb/. Keys are required
# only to RE-EMBED (run_embed.py) or to run the LLM baselines (baselines_llm.py).

# --- embedding / LLM backends (only needed to re-embed or re-run baselines) ---
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...
GEMINI_EMBED_MODEL=gemini-embedding-2

# HuggingFace Inference Endpoints (qwen8b / harrier27b TEI/vLLM, and the safeguard LLM).
HF_TOKEN=hf_...
HF_QWEN_ENDPOINT_URL=https://<endpoint>/v1
HF_HARRIER_ENDPOINT_URL=https://<endpoint>/v1
HF_GPT_SAFEGUARD_20B_ENDPOINT_URL=https://<endpoint>/v1